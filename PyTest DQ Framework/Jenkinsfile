pipeline {
    agent any
    
    environment {
        // credantials
        DB_CREDS = credentials('postgres_db_credentials')
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                dir('PyTest DQ Framework') {
                    sh 'pip install --upgrade pip'
                    sh 'pip install -r requirements.txt --break-system-packages'
                }
            }
        }
        
        stage('Run Data Quality Tests') {
            steps {
                dir('PyTest DQ Framework') {
                    sh """
                    # Створюємо папку для звіту, якщо її немає
                    mkdir -p html_report
                    
                    # Запуск тестів
                    pytest tests -m "parquet_data" \
                    --db_host="localhost" \
                    --db_port="5434" \
                    --db_name="mydatabase" \
                    --db_user="${DB_CREDS_USR}" \
                    --db_password="${DB_CREDS_PSW}" \
                    --html=html_report/report.html --self-contained-html
                    """
                }
            }
        }
    }
    
    post {
        always {
            // publish the report
            publishHTML(target: [
                allowMissing: false,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'PyTest DQ Framework/html_report',
                reportFiles: 'report.html',
                reportName: 'Data Quality Report'
            ])
        }
    }
}