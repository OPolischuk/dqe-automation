pipeline {
    agent any
    
    environment {
        DB_CREDS = credentials('postgres_db_credentials')
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        
        stage('Install Dependencies') {
            steps {
                dir('PyTest DQ Framework') {
                    sh '''
                    # virtual env
                    python3 -m venv venv
                    # install virtual env
                    ./venv/bin/pip install --upgrade pip
                    ./venv/bin/pip install -r requirements.txt
                    '''
                }
            }
        }
        
        stage('Run Data Quality Tests') {
            steps {
                dir('PyTest DQ Framework') {
                    sh """
                    # create folder for report
                    mkdir -p html_report
                    
                    # run pytest
                    ./venv/bin/pytest tests -m "parquet_data" \
                    --db_host="host.containers.internal" \
                    --db_port="5432" \
                    --db_name="mydatabase" \
                    --db_user="${DB_CREDS_USR}" \
                    --db_password="${DB_CREDS_PSW}" \
                    --html=html_report/report.html --self-contained-html || true
                    """
                }
            }
        }
    }
    
    post {
        always {
            // folder
            publishHTML(target: [
                allowMissing: true,
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'PyTest DQ Framework/html_report',
                reportFiles: 'report.html',
                reportName: 'Data Quality Report'
            ])
        }
    }
}